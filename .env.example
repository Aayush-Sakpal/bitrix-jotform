# SERVER
PORT=3000
NODE_ENV=production

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=replace_with_a_long_random_string

# ─────────────────────────────────────────────────────────────────────────────
# OPTION A — ACTIVE
# Each department has its OWN separate Bitrix24 portal.
# The key (FACILITIES, BIOMEDICAL, ADMIN) must be UPPERCASE.
# Add the key to BITRIX_DEPARTMENTS, then add its 3 variables below.
# ─────────────────────────────────────────────────────────────────────────────

# BITRIX_DEPARTMENTS=FACILITIES,BIOMEDICAL,ADMIN

# # Facilities Department
# BITRIX_FACILITIES_DOMAIN=facilities.bitrix24.com
# BITRIX_FACILITIES_USER_ID=1
# BITRIX_FACILITIES_TOKEN=your_facilities_token_here

# # Bio-medical Department
# BITRIX_BIOMEDICAL_DOMAIN=biomedical.bitrix24.com
# BITRIX_BIOMEDICAL_USER_ID=1
# BITRIX_BIOMEDICAL_TOKEN=your_biomedical_token_here

# # Admin Department
# BITRIX_ADMIN_DOMAIN=admin.bitrix24.com
# BITRIX_ADMIN_USER_ID=11
# BITRIX_ADMIN_TOKEN=your_admin_token_here

# ─────────────────────────────────────────────────────────────────────────────
# OPTION B — COMMENTED OUT
# ALL departments share ONE single Bitrix24 portal.
#
# To switch to this option:
#   1. Comment out all OPTION A variables above
#   2. Uncomment the variables below
#   3. In src/config/index.ts, swap the active/commented loadDepartments lines
#   4. Restart the server
# ─────────────────────────────────────────────────────────────────────────────

BITRIX_DEPARTMENTS=FACILITIES,BIOMEDICAL,ADMIN
BITRIX_DOMAIN=company.bitrix24.in
BITRIX_USER_ID=11
BITRIX_TOKEN=TOKEN_HERE

# ─────────────────────────────────────────────────────────────────────────────
# SHARED SETTINGS — apply to both options above
# ─────────────────────────────────────────────────────────────────────────────

# Bitrix24 allows max 2 REST API calls/second per user
BITRIX_RATE_LIMIT_PER_SECOND=2

MAX_RETRIES=5
RETRY_DELAY_MS=3000
LOG_LEVEL=info
ALLOWED_ORIGINS=*